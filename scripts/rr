#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$0"
if command -v realpath >/dev/null 2>&1; then
  SCRIPT_PATH="$(realpath "$SCRIPT_PATH")"
elif command -v readlink >/dev/null 2>&1; then
  RESOLVED="$(readlink "$SCRIPT_PATH" 2>/dev/null || true)"
  if [[ -n "$RESOLVED" ]]; then
    [[ "$RESOLVED" = /* ]] && SCRIPT_PATH="$RESOLVED" || SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && cd "$(dirname "$RESOLVED")" && pwd)/$(basename "$RESOLVED")"
  fi
fi
ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
source "$ROOT/scripts/lib/common.sh"
source "$ROOT/scripts/lib/config.sh"
source "$ROOT/scripts/lib/validate.sh"
source "$ROOT/scripts/lib/selector.sh"
source "$ROOT/scripts/lib/policy.sh"
source "$ROOT/scripts/lib/target.sh"
source "$ROOT/scripts/lib/report.sh"
source "$ROOT/scripts/lib/audit.sh"
source "$ROOT/scripts/lib/lock.sh"
source "$ROOT/scripts/actions/health.sh"
source "$ROOT/scripts/actions/deploy.sh"
source "$ROOT/scripts/actions/logs.sh"
source "$ROOT/scripts/actions/status.sh"
source "$ROOT/scripts/actions/metrics.sh"
source "$ROOT/scripts/actions/sync.sh"
source "$ROOT/scripts/actions/restart.sh"
source "$ROOT/scripts/actions/rollback.sh"
source "$ROOT/scripts/actions/diagnose.sh"
source "$ROOT/scripts/actions/exec.sh"
source "$ROOT/scripts/actions/compare.sh"
source "$ROOT/scripts/actions/port-check.sh"
source "$ROOT/scripts/actions/smoke-test.sh"
source "$ROOT/scripts/actions/build.sh"
source "$ROOT/scripts/actions/package.sh"
source "$ROOT/scripts/actions/backup.sh"
source "$ROOT/scripts/actions/upload.sh"
source "$ROOT/scripts/actions/switch_release.sh"

DRY_RUN=false
YES=false
VERBOSE=false
JSON=false
PARALLEL=false
SERIAL=false
LIMIT=0
TIMEOUT=10
TAIL=200
FOLLOW=false
NO_COLOR=false
REPORT=false

usage() {
  cat <<U
rr help
rr version
rr init
rr doctor
rr validate
rr host plan-add --env <env> --name <host> --ssh-alias <alias> --host <address> --user <user>
rr host add --env <env> --name <host> --ssh-alias <alias> --host <address> --user <user>
rr host list
rr host validate <host>
rr host remove <host>
rr env attach <env> <host>
rr ssh doctor <host>
rr ssh bootstrap <host>
rr plan <action> <target>
rr list
rr list hosts|envs|tasks|labels
rr health <target>
rr deploy <target>
rr logs <target>
rr status <target>
rr restart <target>
rr metrics <target>
rr sync <target>
rr rollback <target>
rr diagnose <target>
rr exec <target> "<command>"
rr run <task> <target>
rr compare <target-a> <target-b>
rr lock list
rr lock clear <target>
U
}

ensure_project_config() {
  mkdir -p .remote-runtime
  [[ -f .remote-runtime/inventory.yaml ]] || cp "$ROOT/config/inventory.yaml" .remote-runtime/inventory.yaml
  [[ -f .remote-runtime/environments.yaml ]] || cp "$ROOT/config/environments.yaml" .remote-runtime/environments.yaml
  [[ -f .remote-runtime/tasks.yaml ]] || cp "$ROOT/config/tasks.yaml" .remote-runtime/tasks.yaml
  [[ -f .remote-runtime/runtime.yaml ]] || cp "$ROOT/config/runtime.yaml" .remote-runtime/runtime.yaml
}

ensure_ssh_include() {
  local ssh_dir="${RR_SSH_CONFIG_DIR:-$HOME/.ssh/config.d}"
  local ssh_config="${RR_SSH_CONFIG_FILE:-$HOME/.ssh/config}"
  mkdir -p "$ssh_dir"
  touch "$ssh_config"
  if ! grep -Fq 'Include ~/.ssh/config.d/*.conf' "$ssh_config"; then
    printf '\nInclude ~/.ssh/config.d/*.conf\n' >> "$ssh_config"
  fi
}

parse_host_add_args() {
  HOST_ENV=""
  HOST_NAME=""
  HOST_ALIAS=""
  HOST_ADDRESS=""
  HOST_USER=""
  HOST_TYPE="lan"
  HOST_PROVIDER="home"
  HOST_LOCATION="local"
  HOST_ROLE="test"
  HOST_INDEX="01"
  HOST_SERVICE_NAME="myapp"
  HOST_DEPLOY_METHOD="jar-systemd"
  HOST_WORKDIR="/opt/apps/myapp"
  HOST_HEALTH_URL="http://127.0.0.1:8080/actuator/health"
  HOST_LABELS="test,onboarded"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --env) HOST_ENV="$2"; shift ;;
      --name) HOST_NAME="$2"; shift ;;
      --ssh-alias) HOST_ALIAS="$2"; shift ;;
      --host) HOST_ADDRESS="$2"; shift ;;
      --user) HOST_USER="$2"; shift ;;
      --type) HOST_TYPE="$2"; shift ;;
      --provider) HOST_PROVIDER="$2"; shift ;;
      --location) HOST_LOCATION="$2"; shift ;;
      --role) HOST_ROLE="$2"; shift ;;
      --index) HOST_INDEX="$2"; shift ;;
      --service-name) HOST_SERVICE_NAME="$2"; shift ;;
      --deploy-method) HOST_DEPLOY_METHOD="$2"; shift ;;
      --workdir) HOST_WORKDIR="$2"; shift ;;
      --health-url) HOST_HEALTH_URL="$2"; shift ;;
      --labels) HOST_LABELS="$2"; shift ;;
      *) die "unknown host add option: $1" ;;
    esac
    shift
  done

  [[ -z "$HOST_ENV" ]] && die "missing --env"
  [[ -z "$HOST_NAME" ]] && die "missing --name"
  [[ -z "$HOST_ALIAS" ]] && die "missing --ssh-alias"
  [[ -z "$HOST_ADDRESS" ]] && die "missing --host"
  [[ -z "$HOST_USER" ]] && die "missing --user"
  if [[ "$HOST_ALIAS" =~ [[:space:]] ]]; then
    die "ssh alias must not contain spaces"
  fi
}

print_host_plan() {
  echo "host add plan"
  echo "  env: $HOST_ENV"
  echo "  name: $HOST_NAME"
  echo "  ssh_alias: $HOST_ALIAS"
  echo "  address: $HOST_ADDRESS"
  echo "  user: $HOST_USER"
  echo "  role: $HOST_ROLE"
  echo "  provider: $HOST_PROVIDER"
  echo "  location: $HOST_LOCATION"
  echo "  inventory: .remote-runtime/inventory.yaml"
  echo "  environments: .remote-runtime/environments.yaml"
  echo "  ssh_config: ~/.ssh/config.d/remote-runtime.conf"
  echo "  secrets: passwords are never stored"
}

write_host_config() {
  require_cmd yq
  ensure_project_config
  yq eval -i ".hosts.\"$HOST_NAME\" = {
    \"type\": \"$HOST_TYPE\",
    \"provider\": \"$HOST_PROVIDER\",
    \"location\": \"$HOST_LOCATION\",
    \"role\": \"$HOST_ROLE\",
    \"index\": \"$HOST_INDEX\",
    \"ssh_alias\": \"$HOST_ALIAS\",
    \"description\": \"Onboarded host\",
    \"labels\": (\"$HOST_LABELS\" | split(\",\")),
    \"vars\": {
      \"service_name\": \"$HOST_SERVICE_NAME\",
      \"deploy_method\": \"$HOST_DEPLOY_METHOD\",
      \"health_url\": \"$HOST_HEALTH_URL\",
      \"workdir\": \"$HOST_WORKDIR\"
    }
  }" .remote-runtime/inventory.yaml
  attach_env_host "$HOST_ENV" "$HOST_NAME"
}

write_ssh_config() {
  ensure_ssh_include
  local ssh_dir="${RR_SSH_CONFIG_DIR:-$HOME/.ssh/config.d}"
  local rr_ssh_config="$ssh_dir/remote-runtime.conf"
  touch "$rr_ssh_config"
  if grep -Eq "^[[:space:]]*Host[[:space:]]+${HOST_ALIAS}\$" "$rr_ssh_config"; then
    echo "ssh alias already exists: $HOST_ALIAS"
    return 0
  fi
  {
    printf '\nHost %s\n' "$HOST_ALIAS"
    printf '  HostName %s\n' "$HOST_ADDRESS"
    printf '  User %s\n' "$HOST_USER"
    printf '  Port 22\n'
  } >> "$rr_ssh_config"
}

attach_env_host() {
  local env="$1" host="$2"
  ensure_project_config
  if ! yq eval -e ".environments.\"$env\"" .remote-runtime/environments.yaml >/dev/null 2>&1; then
    yq eval -i ".environments.\"$env\" = {\"description\":\"Auto-created environment\",\"protected\":false,\"strategy\":\"serial\",\"hosts\":[],\"vars\":{}}" .remote-runtime/environments.yaml
  fi
  yq eval -i ".environments.\"$env\".hosts += [\"$host\"] | .environments.\"$env\".hosts |= unique" .remote-runtime/environments.yaml
}

host_command() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    plan-add)
      parse_host_add_args "$@"
      print_host_plan
      ;;
    add)
      parse_host_add_args "$@"
      write_host_config
      write_ssh_config
      echo "host added: $HOST_NAME"
      echo "ssh alias: $HOST_ALIAS"
      ;;
    list)
      build_compiled_configs >/dev/null
      yq eval '.hosts | keys | .[]' "$CFG_DIR/inventory.yaml"
      ;;
    validate)
      local host="${1:-}"
      [[ -z "$host" ]] && die "usage: rr host validate <host>"
      build_compiled_configs >/dev/null
      yq eval -e ".hosts.\"$host\"" "$CFG_DIR/inventory.yaml" >/dev/null || die "unknown host: $host"
      local alias
      alias="$(yq eval ".hosts.\"$host\".ssh_alias" "$CFG_DIR/inventory.yaml")"
      [[ "$alias" == "null" || -z "$alias" ]] && die "missing ssh_alias for $host"
      echo "host valid: $host"
      ;;
    remove)
      local host="${1:-}"
      [[ -z "$host" ]] && die "usage: rr host remove <host>"
      ensure_project_config
      yq eval -i "del(.hosts.\"$host\")" .remote-runtime/inventory.yaml
      yq eval -i "(.environments[]?.hosts // []) |= map(select(. != \"$host\"))" .remote-runtime/environments.yaml
      echo "host removed from project config: $host"
      ;;
    *) die "usage: rr host plan-add|add|list|validate|remove" ;;
  esac
}

env_command() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    attach)
      [[ $# -ne 2 ]] && die "usage: rr env attach <env> <host>"
      attach_env_host "$1" "$2"
      echo "attached $2 to env:$1"
      ;;
    *) die "usage: rr env attach <env> <host>" ;;
  esac
}

ssh_command() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    doctor)
      local host="${1:-}"
      [[ -z "$host" ]] && die "usage: rr ssh doctor <host>"
      build_compiled_configs >/dev/null
      local alias
      alias="$(yq eval ".hosts.\"$host\".ssh_alias" "$CFG_DIR/inventory.yaml")"
      [[ "$alias" == "null" || -z "$alias" ]] && die "missing ssh_alias for $host"
      ssh -G "$alias" >/dev/null 2>&1 && echo "ssh alias resolvable: $alias" || die "ssh alias not resolvable: $alias"
      ;;
    bootstrap)
      local host="${1:-}"
      [[ -z "$host" ]] && die "usage: rr ssh bootstrap <host>"
      build_compiled_configs >/dev/null
      local alias key
      alias="$(yq eval ".hosts.\"$host\".ssh_alias" "$CFG_DIR/inventory.yaml")"
      key="$HOME/.ssh/remote-runtime_${host}"
      [[ -f "$key" ]] || ssh-keygen -t ed25519 -f "$key" -N ""
      echo "public key: ${key}.pub"
      echo "run: ssh-copy-id -i ${key}.pub ${alias}"
      ;;
    *) die "usage: rr ssh doctor|bootstrap <host>" ;;
  esac
}

parse_flags() {
  local rest=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=true ;;
      --yes) YES=true ;;
      --verbose) VERBOSE=true ;;
      --json) JSON=true ;;
      --parallel) PARALLEL=true ;;
      --serial) SERIAL=true ;;
      --limit) LIMIT="$2"; shift ;;
      --timeout) TIMEOUT="$2"; shift ;;
      --tail) TAIL="$2"; shift ;;
      --follow) FOLLOW=true ;;
      --no-color) NO_COLOR=true ;;
      --report) REPORT=true ;;
      *) rest+=("$1") ;;
    esac
    shift
  done
  set -- "${rest[@]}"
  CMD_ARGS=("$@")
}

doctor() {
  local ok=true
  for c in yq ssh scp rsync curl bash; do
    command -v "$c" >/dev/null 2>&1 || { echo "missing: $c"; ok=false; }
  done
  build_compiled_configs >/dev/null || ok=false
  yq eval '.hosts | keys | length' "$CFG_DIR/inventory.yaml" >/dev/null 2>&1 || ok=false
  yq eval '.environments | keys | length' "$CFG_DIR/environments.yaml" >/dev/null 2>&1 || ok=false
  yq eval '.policies | keys | length' "$CFG_DIR/policies.yaml" >/dev/null 2>&1 || ok=false
  while IFS= read -r h; do
    [[ -z "$h" ]] && continue
    local alias workdir health
    alias="$(yq eval ".hosts.\"$h\".ssh_alias" "$CFG_DIR/inventory.yaml")"
    workdir="$(yq eval ".hosts.\"$h\".vars.workdir" "$CFG_DIR/inventory.yaml")"
    health="$(yq eval ".hosts.\"$h\".vars.health_url" "$CFG_DIR/inventory.yaml")"
    [[ "$alias" == "null" || -z "$alias" ]] && { echo "missing ssh_alias for $h"; ok=false; }
    [[ "$workdir" == "null" || -z "$workdir" ]] && { echo "missing workdir for $h"; ok=false; }
    [[ "$health" == "null" || -z "$health" ]] && { echo "missing health_url for $h"; ok=false; }
  done < <(yq eval '.hosts | keys | .[]' "$CFG_DIR/inventory.yaml")
  $ok && echo "doctor ok" || die "doctor failed"
}

do_init() {
  mkdir -p .remote-runtime
  local svc="${SERVICE_NAME:-myapp}" dep="${DEPLOY_METHOD:-jar-systemd}" cloud="${CLOUD_ALIAS:-jdcloud}" lan="${LAN_ALIAS:-intranet}" health="${HEALTH_URL:-http://127.0.0.1:8080/actuator/health}" wd="${WORKDIR:-/opt/apps/myapp}"
  cat > .remote-runtime/inventory.yaml <<Y
hosts:
  cloud-jd-bj-app-01:
    type: cloud
    provider: jd
    location: bj
    role: app
    index: "01"
    ssh_alias: $cloud
    labels: [java, test]
    vars:
      service_name: $svc
      deploy_method: $dep
      health_url: $health
      workdir: $wd
  lan-office-local-app-01:
    type: lan
    provider: office
    location: local
    role: app
    index: "01"
    ssh_alias: $lan
    labels: [java, test]
    vars:
      service_name: $svc
      deploy_method: $dep
      health_url: $health
      workdir: $wd
Y
  cp "$ROOT/config/environments.yaml" .remote-runtime/environments.yaml
  cp "$ROOT/config/tasks.yaml" .remote-runtime/tasks.yaml
  cp "$ROOT/config/runtime.yaml" .remote-runtime/runtime.yaml
  echo "initialized .remote-runtime"
}

run_task() {
  local task="$1" target="$2"
  build_compiled_configs >/dev/null
  local step
  while IFS= read -r step; do
    [[ -z "$step" ]] && continue
    case "$step" in
      health) action_health "$target" "$DRY_RUN" "$JSON" "$TIMEOUT" ;;
      status) action_status "$target" "$DRY_RUN" ;;
      metrics) action_metrics "$target" "$DRY_RUN" ;;
      logs) action_logs "$target" "$DRY_RUN" "$TAIL" "$FOLLOW" ;;
      restart) action_restart "$target" "$DRY_RUN" ;;
      rollback) action_rollback "$target" "$DRY_RUN" ;;
      report) [[ "$REPORT" == "true" ]] && write_report "$task" "$target" "task done" >/dev/null || true ;;
      smoke-test) action_smoke_test "$target" "$DRY_RUN" ;;
      port-check) action_port_check "$target" "$DRY_RUN" ;;
      build) action_build "$target" "$DRY_RUN" ;;
      package) action_package "$target" "$DRY_RUN" ;;
      backup) action_backup "$target" "$DRY_RUN" ;;
      upload) action_upload "$target" "$DRY_RUN" ;;
      switch_release) action_switch_release "$target" "$DRY_RUN" ;;
      *) echo "skip unknown step: $step" ;;
    esac
  done < <(yq eval ".tasks.\"$task\".steps[]" "$CFG_DIR/tasks.yaml" 2>/dev/null || true)
}

parse_flags "$@"
set -- "${CMD_ARGS[@]}"

cmd="${1:-help}"
case "$cmd" in
  help) usage ;;
  version) cat "$ROOT/VERSION" ;;
  doctor) doctor ;;
  validate) validate_configs ;;
  init)
    shift
    if [[ "${1:-}" == "--non-interactive" ]]; then
      shift
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --service-name) SERVICE_NAME="$2"; shift ;;
          --deploy-method) DEPLOY_METHOD="$2"; shift ;;
          --cloud-alias) CLOUD_ALIAS="$2"; shift ;;
          --lan-alias) LAN_ALIAS="$2"; shift ;;
          --health-url) HEALTH_URL="$2"; shift ;;
          --workdir) WORKDIR="$2"; shift ;;
        esac
        shift
      done
      do_init
    else
      read -r -p "service_name [myapp]: " SERVICE_NAME; SERVICE_NAME="${SERVICE_NAME:-myapp}"
      read -r -p "deploy_method [jar-systemd]: " DEPLOY_METHOD; DEPLOY_METHOD="${DEPLOY_METHOD:-jar-systemd}"
      read -r -p "cloud_alias [jdcloud]: " CLOUD_ALIAS; CLOUD_ALIAS="${CLOUD_ALIAS:-jdcloud}"
      read -r -p "lan_alias [intranet]: " LAN_ALIAS; LAN_ALIAS="${LAN_ALIAS:-intranet}"
      read -r -p "health_url [http://127.0.0.1:8080/actuator/health]: " HEALTH_URL; HEALTH_URL="${HEALTH_URL:-http://127.0.0.1:8080/actuator/health}"
      read -r -p "workdir [/opt/apps/myapp]: " WORKDIR; WORKDIR="${WORKDIR:-/opt/apps/myapp}"
      do_init
    fi
    ;;
  host)
    shift
    host_command "$@"
    ;;
  env)
    shift
    env_command "$@"
    ;;
  ssh)
    shift
    ssh_command "$@"
    ;;
  list)
    build_compiled_configs >/dev/null
    sub="${2:-hosts}"
    case "$sub" in
      hosts) yq eval '.hosts | keys | .[]' "$CFG_DIR/inventory.yaml" ;;
      envs) yq eval '.environments | keys | .[]' "$CFG_DIR/environments.yaml" ;;
      tasks) yq eval '.tasks | keys | .[]' "$CFG_DIR/tasks.yaml" ;;
      labels) yq eval '.hosts[].labels[]' "$CFG_DIR/inventory.yaml" | sort -u ;;
      *) die "unknown list subcommand" ;;
    esac
    ;;
  plan)
    action="${2:-}"; target="${3:-}"
    [[ -z "$action" || -z "$target" ]] && die "usage: rr plan <action> <target>"
    echo "plan action=$action target=$target dry_run=$DRY_RUN"
    echo "1) resolve target"
    echo "2) check policy"
    echo "3) execute action"
    ;;
  health) action_health "${2:-}" "$DRY_RUN" "$JSON" "$TIMEOUT" ;;
  deploy) action_deploy "${2:-}" "$DRY_RUN" ;;
  logs) action_logs "${2:-}" "$DRY_RUN" "$TAIL" "$FOLLOW" ;;
  status) action_status "${2:-}" "$DRY_RUN" ;;
  restart) action_restart "${2:-}" "$DRY_RUN" ;;
  metrics) action_metrics "${2:-}" "$DRY_RUN" ;;
  sync) action_sync "${2:-}" "$DRY_RUN" ;;
  rollback) action_rollback "${2:-}" "$DRY_RUN" ;;
  diagnose) action_diagnose "${2:-}" "$DRY_RUN" ;;
  exec) action_exec "${2:-}" "$DRY_RUN" "${3:-}" ;;
  run) run_task "${2:-}" "${3:-}" ;;
  compare) action_compare "${2:-}" "${3:-}" "$DRY_RUN" ;;
  lock)
    case "${2:-}" in
      list) lock_list ;;
      clear) lock_clear "${3:-}" ;;
      *) die "usage: rr lock list|clear <target>" ;;
    esac
    ;;
  *) usage; exit 1 ;;
esac
